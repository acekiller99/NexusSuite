# ============================================================
# AlphaEdge — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# ---------- General ----------
APP_NAME=AlphaEdge
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------- Database (PostgreSQL) ----------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=alphaedge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=alphaedge

# Async connection string (constructed from above)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---------- Celery ----------
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ---------- JWT Auth ----------
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ---------- Market Data (free APIs) ----------
# Yahoo Finance (via yfinance library, no key needed)
# Alpha Vantage (free tier)
ALPHA_VANTAGE_API_KEY=

# ---------- Trading (paper trading by default) ----------
TRADING_MODE=paper
# Alpaca (free paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---------- Logging ----------
LOG_LEVEL=INFO
